{
  "name": "plot-armor",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:main": "vite build",
    "build:content:reddit": "CONTENT_ENTRY=reddit vite build --config vite.config.content.ts",
    "build:content:twitter": "CONTENT_ENTRY=twitter vite build --config vite.config.content.ts",
    "build:content:youtube": "CONTENT_ENTRY=youtube vite build --config vite.config.content.ts",
    "build:content": "npm run build:content:reddit && npm run build:content:twitter && npm run build:content:youtube",
    "build": "npm run build:main && npm run build:content",
    "dev": "npm run build:main -- --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.268",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.3",
    "vite": "^5.3.4",
    "vitest": "^1.6.0"
  }
}
